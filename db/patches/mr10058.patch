-        fs32_sel = alloc_fs_sel( -1, wow_teb );
-#elif defined(__APPLE__)
-        cs32_sel = ldt_alloc_entry( ldt_make_cs32_entry() );
-#endif
-    }
-
+    init_wow_sel();
     signal_alloc_thread( NtCurrentTeb() );
 
     sig_act.sa_mask = server_block_set;
