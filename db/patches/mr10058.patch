From 0d263ab9f4e3f7d15d53e744e180bc921d44e58a Mon Sep 17 00:00:00 2001
From: =?UTF-8?q?R=C3=A9mi=20Bernon?= <rbernon@codeweavers.com>
Date: Fri, 13 Feb 2026 23:19:34 +0100
Subject: [PATCH 02/12] ntdll: Pass the main thread flags in the new_process
 request.

---
 dlls/ntdll/unix/process.c |  3 ++-
 server/process.c          | 11 ++++++-----
 server/process.h          |  1 +
 server/protocol.def       |  3 ++-
 4 files changed, 11 insertions(+), 7 deletions(-)

diff --git a/dlls/ntdll/unix/process.c b/dlls/ntdll/unix/process.c
