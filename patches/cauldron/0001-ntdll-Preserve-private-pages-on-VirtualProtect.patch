From 6355ea2ff87385af9a274cb631d3250ed01679c5 Mon Sep 17 00:00:00 2001
From: Cauldron <cauldron@cauldron.app>
Date: Tue, 7 Apr 2026 02:46:55 -0500
Subject: [PATCH] ntdll: Track COW-written pages (safe version)

---
 dlls/ntdll/unix/virtual.c | 19 +++++++++++++++++++
 1 file changed, 19 insertions(+)

diff --git a/dlls/ntdll/unix/virtual.c b/dlls/ntdll/unix/virtual.c
index 9297a5f..40fa920 100644
--- a/dlls/ntdll/unix/virtual.c
+++ b/dlls/ntdll/unix/virtual.c
@@ -138,6 +138,7 @@ struct file_view
 #define VPROT_GUARD      0x10
 #define VPROT_COMMITTED  0x20
 #define VPROT_WRITEWATCH 0x40
+#define VPROT_WRITTEN    0x80  /* page was COW-written; private copy exists */
 /* per-mapping protection flags */
 #define VPROT_ARM64EC          0x0100  /* view may contain ARM64EC code */
 #define VPROT_SYSTEM           0x0200  /* system view (underlying mmap not under our control) */
@@ -1984,6 +1985,10 @@ static int mprotect_range( void *base, size_t size, BYTE set, BYTE clear )
  */
 static BOOL set_vprot( struct file_view *view, void *base, size_t size, BYTE vprot )
 {
+    /* Cauldron: preserve VPROT_WRITTEN across protection changes */
+    BYTE old_vprot = get_host_page_vprot( base );
+    if (old_vprot & VPROT_WRITTEN) vprot |= VPROT_WRITTEN;
+
     if (!use_kernel_writewatch && view->protect & VPROT_WRITEWATCH)
     {
         /* each page may need different protections depending on write watch flag */
@@ -4598,6 +4603,20 @@ NTSTATUS virtual_handle_fault( EXCEPTION_RECORD *rec, void *stack )
                 mprotect_range( page, host_page_size, 0, 0 );
             }
         }
+        /* Cauldron: track COW writes on WRITECOPY pages so VirtualProtect
+         * doesn't discard private pages when restoring read-only protection. */
+        if ((vprot & VPROT_WRITECOPY) && !(vprot & VPROT_WRITTEN))
+        {
+            set_page_vprot_bits( page, host_page_size, VPROT_WRITE | VPROT_WRITTEN, VPROT_WRITECOPY );
+            mprotect_range( page, host_page_size, 0, 0 );
+            ret = STATUS_SUCCESS;
+        }
+        else if ((vprot & VPROT_WRITTEN) && !(get_unix_prot( vprot ) & PROT_WRITE))
+        {
+            set_page_vprot_bits( page, host_page_size, VPROT_WRITE, 0 );
+            mprotect_range( page, host_page_size, 0, 0 );
+            ret = STATUS_SUCCESS;
+        }
         /* ignore fault if page is writable now */
         if (get_unix_prot( get_host_page_vprot( page )) & PROT_WRITE)
         {
